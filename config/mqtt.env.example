# MQTT Weather Station Configuration
# Copy this file to mqtt.env and customize for your setup
# Load with: set -a; source mqtt.env; set +a && python3 mqtt.py

MQTT_SERVER=mqtt.example.com
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=weatherhat-pi
MQTT_TOPIC_PREFIX=sensors
TEMP_OFFSET=-7.5
UPDATE_INTERVAL=2.0
PUBLISH_INTERVAL=5.0

# Home Assistant MQTT Discovery (default: true, set to false to disable)
HA_DISCOVERY=true
